# Paychangu API Configuration
# Get your keys from https://dashboard.paychangu.com

# Required - Your Paychangu secret key
PAYCHANGU_SECRET_KEY=your_secret_key_here

# Optional - Callback URLs for payment feedback
CALLBACK_URL=http://localhost:3001/paychangu/callback
RETURN_URL=http://localhost:3000/payment-success

# Server Configuration
PORT=3001

